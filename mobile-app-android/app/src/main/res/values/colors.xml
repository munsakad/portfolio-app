<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ══════════════════════════════════════════
         PERSONAL BRAND KIT — Color Palette
         Primary:   Deep Navy   #03045E
         Secondary: Ocean Blue  #0077B6
         Accent:    Cyan        #00B4D8
         Light:     Sky Cyan    #90E0EF
         Surface:   Dark Card   #1A1A2E
    ══════════════════════════════════════════ -->

    <!-- Brand Primary -->
    <color name="brand_primary">#03045E</color>
    <color name="brand_secondary">#0077B6</color>
