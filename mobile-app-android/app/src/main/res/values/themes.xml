<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PortfolioApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_secondary</item>
        <item name="colorPrimaryVariant">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/brand_primary</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <style name="Theme.PortfolioApp.Splash" parent="Theme.PortfolioApp">
        <item name="android:windowBackground">@color/brand_primary</item>
    </style>

    <!-- Brand Button Style -->
    <style name="BrandButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/brand_accent</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_accent</item>
        <item name="android:textColor">@color/brand_accent</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Brand Card -->
    <style name="BrandCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Input Field -->
    <style name="BrandInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brand_accent</item>
        <item name="hintTextColor">@color/brand_light</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <!-- Avatar Circle -->
    <style name="AvatarText">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_avatar</item>
    </style>
</resources>
