<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/surface_dark" android:orientation="vertical">

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Hero Card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:cardCornerRadius="20dp" app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="24dp" android:gravity="center">

                    <TextView android:id="@+id/tvInitials"
                        android:layout_width="80dp" android:layout_height="80dp"
                        style="@style/AvatarText" android:layout_marginBottom="16dp"/>

                    <TextView android:id="@+id/tvName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginBottom="4dp"/>

                    <TextView android:id="@+id/tvTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="@color/brand_accent"
                        android:layout_marginBottom="8dp"/>

                    <TextView android:id="@+id/tvLocation"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="@color/text_muted"
                        android:layout_marginBottom="16dp"/>

                    <TextView android:id="@+id/tvBio"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/text_muted"
                        android:gravity="center" android:maxLines="3" android:layout_marginBottom="20dp"/>

                    <Button android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content" android:layout_height="44dp"
                        android:text="Edit Profile" android:background="@drawable/bg_button"
                        android:textColor="@color/brand_primary" android:textStyle="bold"
                        android:paddingLeft="24dp" android:paddingRight="24dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_weight="1" android:background="@drawable/bg_stat_card"
                    android:orientation="vertical" android:gravity="center"
                    android:layout_marginEnd="8dp">
                    <TextView android:id="@+id/tvProjectCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="@color/brand_accent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Projects" android:textSize="12sp" android:textColor="@color/text_muted"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_weight="1" android:background="@drawable/bg_stat_card"
                    android:orientation="vertical" android:gravity="center"
                    android:layout_marginStart="8dp">
                    <TextView android:id="@+id/tvSkillCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="@color/brand_accent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Skills" android:textSize="12sp" android:textColor="@color/text_muted"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Quick Actions -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btnViewProjects"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="Projects" android:background="@drawable/bg_card"
                    android:textColor="@color/brand_accent" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnViewAnalytics"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="Analytics" android:background="@drawable/bg_button"
                    android:textColor="@color/brand_primary" android:textStyle="bold"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface_card"
        app:menu="@menu/bottom_nav_menu"
        app:itemTextColor="@color/brand_accent"
        app:itemIconTint="@color/brand_accent"/>
</LinearLayout>
